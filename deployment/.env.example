# Nanoprobe Sim Lab - Production Environment Variables
# Скопируйте в .env и заполните значениями

# ==========================================
# Application
# ==========================================
APP_NAME=nanoprobe-sim-lab
APP_ENV=production
DEBUG=false

# ==========================================
# Database (PostgreSQL)
# ==========================================
DB_USER=nanoprobe
DB_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD
DB_NAME=nanoprobe
DATABASE_URL=postgresql://nanoprobe:CHANGE_ME_TO_SECURE_PASSWORD@postgres:5432/nanoprobe

# ==========================================
# Redis
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==========================================
# Security
# ==========================================
# Сгенерируйте: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_32_CHAR_SECRET_KEY
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================================
# NASA API
# ==========================================
# Получите ключ: https://api.nasa.gov/
NASA_API_KEY=DEMO_KEY

# ==========================================
# CORS
# ==========================================
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ==========================================
# URLs (Production)
# ==========================================
API_URL=https://api.your-domain.com
WS_URL=wss://api.your-domain.com
FRONTEND_URL=https://your-domain.com

# ==========================================
# Monitoring
# ==========================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ==========================================
# VAPID (Push Notifications)
# ==========================================
# Сгенерируйте: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=admin@your-domain.com

# ==========================================
# SSL/TLS (для production)
# ==========================================
# Для Let's Encrypt раскомментируйте:
# SSL_CERTIFICATE=/etc/nginx/ssl/fullchain.pem
# SSL_CERTIFICATE_KEY=/etc/nginx/ssl/privkey.pem

# ==========================================
# Docker
# ==========================================
COMPOSE_PROJECT_NAME=nanoprobe
