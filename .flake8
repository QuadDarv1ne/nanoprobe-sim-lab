[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    build,
    dist,
    venv,
    .venv
ignore = E203, W503, E402

per-file-ignores =
    # Циклические импорты в утилитах оптимизации (sys.path.append требуется)
    utils/ai_resource_optimizer.py: E402
    utils/automated_optimization_scheduler.py: E402
    utils/optimization_orchestrator.py: E402
    utils/performance_analytics_dashboard.py: E402
    utils/performance_monitoring_center.py: E402
    utils/performance_verification_framework.py: E402
    utils/predictive_analytics_engine.py: E402
    utils/realtime_dashboard.py: E402
    utils/self_healing_system.py: E402
