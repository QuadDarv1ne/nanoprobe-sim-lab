# Переменные окружения для FastAPI API
# Скопируйте этот файл в .env и заполните значениями

# JWT Secret (обязательно измените для production!)
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Database
DATABASE_PATH=data/nanoprobe.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# CORS (разрешённые origin)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5000","http://127.0.0.1:5000"]

# JWT Settings
JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7

# Redis (опционально)
REDIS_URL=redis://localhost:6379

# Sentry (опционально)
SENTRY_DSN=
