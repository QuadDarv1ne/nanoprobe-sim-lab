# Переменные окружения для FastAPI API
# Скопируйте этот файл в .env и заполните значениями

# ==================== Безопасность ====================
# JWT Secret (обязательно измените для production!)
JWT_SECRET=your-super-secret-key-change-in-production-min-32-chars

# Отладка API (не включать в production!)
API_DEBUG=false

# ==================== Database ====================
DATABASE_PATH=data/nanoprobe.db

# ==================== Network & Ports ====================
# Порты сервисов (поддерживается автоопределение)
BACKEND_PORT=8000        # FastAPI Backend
FLASK_PORT=5000          # Flask Frontend
NEXTJS_PORT=3000         # Next.js Frontend

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# ==================== CORS ====================
# Формат JSON: ["url1","url2"] или CSV: url1,url2
CORS_ORIGINS=["http://localhost:3000","http://localhost:5000","http://127.0.0.1:5000"]

# ==================== JWT Settings ====================
# JWT expiration in minutes (1 hour default)
JWT_EXPIRATION_MINUTES=60
# Refresh token expiration in days (7 days default)
JWT_REFRESH_EXPIRATION_DAYS=7

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_DB=0                    # Redis database number (default: 0)
REDIS_PASSWORD=               # Redis password (leave empty for no auth)
REDIS_DISABLED=false          # Set true to disable Redis (use in-memory fallback)

# ==================== Default Users ====================
# Admin user credentials
ADMIN_PASSWORD=               # Auto-generated if empty
USER_PASSWORD=                # Auto-generated if empty

# ==================== External Services ====================
# NASA API Key - получите на https://api.nasa.gov/
# DEMO_KEY имеет лимит 30 запросов/час
# Production ключ: 1000 запросов/час (требуется регистрация)
NASA_API_KEY=DEMO_KEY

# NASA API URLs (не менять)
NASA_IMAGE_LIBRARY_URL=https://images-api.nasa.gov
NASA_EARTH_OBSERVATORY_URL=https://eoimages.gsfc.nasa.gov
NASA_APOD_URL=https://api.nasa.gov/planetary/apod

# ==================== Alerting ====================
# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=alerts@nanoprobe-lab.local
TO_EMAILS=

# Slack
SLACK_WEBHOOK_URL=

# Custom Webhook
ALERT_WEBHOOK_URL=

# ==================== Monitoring ====================
SENTRY_DSN=                   # Sentry DSN for error tracking (optional)
APP_VERSION=1.0.0
ENVIRONMENT=production

# ==================== Logging ====================
# Уровень логирования: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=info

# Формат логов: json (для прода/Grafana), human (для dev)
# Если не указан, определяется автоматически из ENVIRONMENT
LOG_FORMAT=
# Путь к файлу логов (опционально)
LOG_FILE=logs/nanoprobe.log

# ==================== SSTV Ground Station ====================
GROUND_STATION_LAT=55.7558    # Moscow latitude (example)
GROUND_STATION_LON=37.6173    # Moscow longitude (example)

# ==================== Waterfall Settings ====================
# Максимальная длительность waterfall записи (минуты)
# 0 = без ограничений (не рекомендуется - высокое потребление памяти)
MAX_WATERFALL_DURATION_MINUTES=60

# FPS waterfall обновления
WATERFALL_FPS=10

# Включить потоковую запись через ffmpeg (true/false)
WATERFALL_STREAMING=true

# Путь для сохранения waterfall видео
WATERFALL_OUTPUT_PATH=output/waterfall

# ==================== Proxy ====================
FASTAPI_URL=http://localhost:8000
